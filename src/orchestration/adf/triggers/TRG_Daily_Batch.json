{
    "name": "TRG_Daily_Batch",
    "properties": {
        "description": "Triggers the batch ingestion and processing pipeline daily at 02:00 UTC.",
        "type": "ScheduleTrigger",
        "typeProperties": {
            "recurrence": {
                "frequency": "Day",
                "interval": 1,
                "startTime": "2024-01-01T02:00:00Z",
                "timeZone": "UTC",
                "schedule": {
                    "minutes": [
                        0
                    ],
                    "hours": [
                        2
                    ]
                }
            }
        },
        "pipelines": [
            {
                "pipelineReference": {
                    "referenceName": "PL_Batch_Ingest_and_Process",
                    "type": "PipelineReference"
                },
                "parameters": {
                    "dlt_batch_pipeline_id": "terraform-injected-batch-id"
                }
            }
        ]
    }
}